# Direnv base config for Phoenix runtime env vars.
# Keep secrets out of git by placing them in .envrc.local

# Use mock AI client for tests, gemini for dev/prod
if [ "$MIX_ENV" = "test" ]; then
  export AI_CLIENT="${AI_CLIENT:-mock}"
else
  export AI_CLIENT="${AI_CLIENT:-gemini}"
fi

export GEMINI_MODEL="${GEMINI_MODEL:-gemini-2.0-flash}"
export GEMINI_TIMEOUT_MS="${GEMINI_TIMEOUT_MS:-15000}"

# Optional server defaults (override in .envrc.local if needed)
# export PORT="4000"
# export PHX_HOST="localhost"
# export SECRET_KEY_BASE="replace_with_generated_secret"

# Social auth defaults and placeholders
# export GOOGLE_OAUTH_CLIENT_IDS="your_google_ios_client_id,your_google_web_client_id"
# export APPLE_OAUTH_CLIENT_IDS="com.myfood.app,com.myfood.web"
# export FACEBOOK_APP_ID="your_facebook_app_id"
# export FACEBOOK_APP_SECRET="your_facebook_app_secret"
export GOOGLE_TOKENINFO_URL="${GOOGLE_TOKENINFO_URL:-https://oauth2.googleapis.com/tokeninfo}"
export APPLE_JWKS_URL="${APPLE_JWKS_URL:-https://appleid.apple.com/auth/keys}"
export FACEBOOK_GRAPH_URL="${FACEBOOK_GRAPH_URL:-https://graph.facebook.com}"

if [[ -f .envrc.local ]]; then
  source_env .envrc.local
fi

if [[ -z "${GEMINI_API_KEY:-}" ]]; then
  echo "[myfood] GEMINI_API_KEY no esta definido. Agregalo en .envrc.local"
fi
